{
  "name": "WhiteHolewithASM",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",
  "postCreateCommand": "bash setup.sh",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "WhiteHole WebGL Preview",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.hexeditor"
      ]
    }
  }
}
